{
  "name": "kolect",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "dev:front": "vite",
    "build": "tauri build",
    "build:front": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "tauri": "tauri",
    "format:front": "biome format --fix",
    "format:front:check": "biome format",
    "format:tauri": "cargo fmt --manifest-path src-tauri/Cargo.toml --all",
    "format:tauri:check": "cargo fmt --manifest-path src-tauri/Cargo.toml --all -- --check",
    "format": "bun format:front && bun format:tauri",
    "format:check": "bun format:front:check && bun format:tauri:check",
    "lint:front": "biome lint --fix",
    "lint:front:check": "biome lint",
    "lint:tauri": "cargo clippy --fix --manifest-path src-tauri/Cargo.toml --allow-dirty",
    "lint:tauri:check": "cargo clippy --manifest-path src-tauri/Cargo.toml --allow-dirty",
    "lint": "bun lint:front && bun lint:tauri",
    "lint:check": "bun lint:front:check && bun lint:tauri:check",
    "migration:revert": "cd src-tauri && diesel migration revert --database-url ~/.local/share/fr.sukaato.kolect/database.db",
    "migration:generate": "cd src-tauri && diesel migration generate --database-url ~/.local/share/fr.sukaato.kolect/database.db",
    "migration:run": "cd src-tauri && diesel migration run --database-url ~/.local/share/fr.sukaato.kolect/database.db",
    "migration:schema": "diesel print-schema --config-file src-tauri/diesel.toml --database-url ~/.local/share/fr.sukaato.kolect/database.db -- --manifest-path src-tauri/Cargo.toml > ./src-tauri/src/infrastructure/db/schema.rs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-fs": "~2.4.5",
    "@tauri-apps/plugin-log": "~2.8.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-store": "~2.4.2",
    "@vueuse/core": "^14.2.1",
    "lucide-vue-next": "^0.577.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "4.1.0",
    "daisyui": "^5.5.19",
    "lefthook": "^2.1.4",
    "sass": "^1.98.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-vue-devtools": "^8.1.0",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.6"
  }
}
